rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Product catalog is public read-only. Writes only via Admin SDK (seed script).
    match /products/{productId} {
      allow read: if true;
      allow write: if false;
    }

    // Anyone can place an order (guest checkout supported); only the owning
    // signed-in user can read their own order history.
    match /orders/{orderId} {
      allow create: if request.resource.data.items is list
                    && request.resource.data.items.size() > 0
                    && request.resource.data.total is number;
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow update, delete: if false;
    }
  }
}
